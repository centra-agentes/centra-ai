NODE_ENV=development
PORT=3000

# ─── Base de datos ────────────────────────────────────────────────────────────
# En Railway se inyecta automáticamente como DATABASE_URL
# En local o VPS usa las variables individuales:
DB_HOST=localhost
DB_PORT=5432
DB_USERNAME=postgres
DB_PASSWORD=postgres
DB_NAME=centravigia
DB_SSL=false

# ─── Rendimiento ─────────────────────────────────────────────────────────────
THROTTLE_TTL=60
THROTTLE_LIMIT=60
CACHE_TTL_SECONDS=300

# ─── Rama Judicial ────────────────────────────────────────────────────────────
RAMA_TIMEOUT_MS=15000
RAMA_MAX_RETRIES=3
RAMA_BASE_URL=https://consultaprocesos.ramajudicial.gov.co/api/Procesos
RAMA_V2_BASE_URL=https://consultaprocesos.ramajudicial.gov.co:448/api/v2
RAMA_PUBLICACIONES_URL=https://publicacionesprocesales.ramajudicial.gov.co
PUBLICACIONES_TIMEOUT_MS=30000
# ID del portlet de publicaciones (verificar en el código fuente de la página si cambia)
PUBLICACIONES_PORTLET_NS=BIyXQFHVaYaq

# ─── Seguridad ───────────────────────────────────────────────────────────────
# Clave maestra para gestionar API keys desde el dashboard
# Genera con: openssl rand -hex 32
MASTER_API_KEY=

# ─── Inteligencia Artificial ─────────────────────────────────────────────────
# Tu API key de Anthropic — el agente usa tu propia cuenta
# El costo de IA corre por tu cuenta (on-premise, tus datos, tu control)
# Obtén una en: https://console.anthropic.com
ANTHROPIC_API_KEY=

# ─── Identidad de instancia ───────────────────────────────────────────────────
# Nombre que identifica esta instancia en logs y en el dashboard
AGENT_INSTANCE_NAME=mi-firma-juridica

# ─── Licencia Centra ─────────────────────────────────────────────────────────
# Licencia de suscripción activa de Centra
# Se valida en el arranque — si no está configurada el agente funciona igual
# pero no recibirá actualizaciones automáticas
CENTRA_LICENSE_KEY=
